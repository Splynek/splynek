<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Enable the App Sandbox. Splynek only needs:
        - Outgoing network access (client)
        - Write access to files the user explicitly picked via NSOpenPanel
          (security-scoped bookmarks are handled by AppKit)
      Everything else stays denied.

      To build with this entitlement file:
        SIGN_IDENTITY="Developer ID Application: …" \
          ENTITLEMENTS=Resources/Splynek.entitlements \
          ./Scripts/build.sh

      Ad-hoc signing with an entitlement file works for local testing but
      some sandbox features require a real identity for full enforcement.
    -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <key>com.apple.security.files.downloads.read-write</key>
    <true/>
    <!--
      S4 phase 3 (2026-05-07): CloudKit over-cellular relay.
      Splynek macOS receives SplynekRelayJob CKRecords written by
      iOS Splynek Companion when the iPhone wasn't on the same Wi-Fi
      as the Mac.  Same container ID as the iOS app so writes from
      one land in the database the other polls.

      `iCloud.app.splynek.companion` must be created in App Store
      Connect, with schema "SplynekRelayJob" published in both
      Development + Production environments, before the receiver's
      pollOnce() will return matching records.  Until then the
      receiver runs but quietly returns 0 ingested per tick.
    -->
    <key>com.apple.developer.icloud-services</key>
    <array>
        <string>CloudKit</string>
    </array>
    <key>com.apple.developer.icloud-container-identifiers</key>
    <array>
        <string>iCloud.app.splynek.companion</string>
    </array>
</dict>
</plist>
