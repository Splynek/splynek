{
  "manifest_version": 3,
  "name": "Splynek — Download with Splynek",
  "short_name": "Splynek",
  "version": "0.23.0",
  "description": "Send links and current pages to Splynek, the macOS multi-interface download aggregator. Optionally intercepts large downloads (>50 MB) so Splynek can finish them on every network you have.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "tabs",
    "storage",
    "webRequest",
    "downloads",
    "notifications"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send to Splynek",
    "default_icon": {
      "16":  "icon-16.png",
      "32":  "icon-32.png",
      "48":  "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16":  "icon-16.png",
    "32":  "icon-32.png",
    "48":  "icon-48.png",
    "128": "icon-128.png"
  },
  "commands": {
    "splynek-download-active-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Download the current tab in Splynek"
    }
  }
}
