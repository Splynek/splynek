    "Remove every completed, failed, and cancelled entry. Running and pending entries are kept.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle abgeschlossenen, fehlgeschlagenen und abgebrochenen Einträge entfernen. Laufende und ausstehende Einträge bleiben erhalten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar todas las entradas completadas, fallidas y canceladas. Las entradas en curso y pendientes se conservan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer toutes les entrées terminées, échouées et annulées. Les entrées en cours et en attente sont conservées."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuovi tutte le voci completate, fallite e annullate. Le voci in esecuzione e in attesa vengono mantenute."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Remover todas as entradas concluídas, falhadas e canceladas. As entradas em curso e pendentes são mantidas."
          }
        }
      }
    },
