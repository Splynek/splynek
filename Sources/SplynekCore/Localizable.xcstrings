    "Downloads, queue, history lookups, and app actions — all through one conversation. Runs on your local LLM, offline.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Downloads, Warteschlange, Verlaufssuchen und App-Aktionen — alles in einem Gespräch. Läuft auf deinem lokalen LLM, offline."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Descargas, cola, búsquedas de historial y acciones de aplicaciones — todo en una sola conversación. Funciona con tu LLM local, sin conexión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Téléchargements, file d'attente, recherches d'historique et actions d'applications — tout dans une seule conversation. Fonctionne sur ton LLM local, hors ligne."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Download, coda, ricerche cronologia e azioni delle app — tutto in una sola conversazione. Funziona sul tuo LLM locale, offline."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Transferências, fila, pesquisas de histórico e ações de apps — tudo numa só conversa. Corre no teu LLM local, offline."
          }
        }
      }
    },
