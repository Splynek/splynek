    },
    "This app is no longer at \\(r.installedAt.path). Forget the entry to clean it up.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese App befindet sich nicht mehr unter \\(r.installedAt.path). Eintrag verwerfen, um aufzuräumen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app ya no está en \\(r.installedAt.path). Olvida la entrada para limpiarla."
          }
        },
        "fr": {
          "stringUnit": {
