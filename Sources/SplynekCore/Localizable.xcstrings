    "Try rephrasing the goal, or pull a larger model. Small models under 3B parameters sometimes struggle with structured JSON output.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Versuche, das Ziel umzuformulieren, oder lade ein größeres Modell. Kleine Modelle unter 3B Parametern haben manchmal Schwierigkeiten mit strukturierter JSON-Ausgabe."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Prueba a reformular el objetivo, o descarga un modelo más grande. Los modelos pequeños bajo 3B parámetros a veces tienen problemas con salida JSON estructurada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Essaie de reformuler l'objectif, ou télécharge un modèle plus grand. Les petits modèles sous 3B paramètres ont parfois du mal avec la sortie JSON structurée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prova a riformulare l'obiettivo, o scarica un modello più grande. I modelli piccoli sotto i 3B parametri a volte faticano con output JSON strutturato."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Tenta reformular o objetivo, ou puxa um modelo maior. Modelos pequenos com menos de 3B parâmetros por vezes têm dificuldades com saída JSON estruturada."
          }
        }
      }
    },
    "Type a goal like \"set up my Mac for iOS dev\"": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie ein Ziel ein wie \"Mac für iOS-Entwicklung einrichten\""
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribe un objetivo como \"configurar mi Mac para desarrollo iOS\""
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tapez un objectif comme \"configurer mon Mac pour le développement iOS\""
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scrivi un obiettivo come \"configura il mio Mac per sviluppo iOS\""
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Escreve um objetivo como \"configurar o meu Mac para desenvolvimento iOS\""
          }
        }
      }
    },
    "Type a goal. The local LLM proposes a multi-step download plan. Available in Splynek Pro.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib ein Ziel ein. Das lokale LLM schlägt einen mehrstufigen Download-Plan vor. Verfügbar in Splynek Pro."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribe un objetivo. El LLM local propone un plan de descargas en varios pasos. Disponible en Splynek Pro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tape un objectif. Le LLM local propose un plan de téléchargement en plusieurs étapes. Disponible dans Splynek Pro."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scrivi un obiettivo. L'LLM locale propone un piano di download in più passaggi. Disponibile in Splynek Pro."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Escreve um objetivo. O LLM local propõe um plano de transferências em vários passos. Disponível no Splynek Pro."
          }
        }
      }
    },
    "Type a goal. Your local LLM proposes a verified batch of downloads. You review, edit, and queue in one click.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib ein Ziel ein. Dein lokales LLM schlägt eine geprüfte Download-Batch vor. Du überprüfst, bearbeitest und reihst mit einem Klick ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribe un objetivo. Tu LLM local propone un lote verificado de descargas. Tú revisas, editas y pones en cola con un clic."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tape un objectif. Ton LLM local propose un lot de téléchargements vérifié. Tu valides, modifies et mets en file d'attente en un clic."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scrivi un obiettivo. Il tuo LLM locale propone un batch di download verificato. Tu controlli, modifichi e accodi con un clic."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Escreve um objetivo. O teu LLM local propõe um lote verificado de transferências. Tu revês, editas e enfileiras com um clique."
          }
        }
      }
    },
    "Type “the latest Ubuntu ISO” instead of a URL. Splynek Pro feature — powered by a local LLM (LM Studio or Ollama) on your Mac.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen Sie “das neueste Ubuntu-ISO” statt einer URL. Splynek-Pro-Funktion — angetrieben von einem lokalen LLM (LM Studio oder Ollama) auf Ihrem Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribe “la última ISO de Ubuntu” en lugar de una URL. Función de Splynek Pro — impulsada por un LLM local (LM Studio u Ollama) en tu Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tapez “la dernière ISO Ubuntu” au lieu d'une URL. Fonctionnalité Splynek Pro — propulsée par un LLM local (LM Studio ou Ollama) sur votre Mac."
          }
        },
        "it": {
