    "All tool calls are logged via os.Logger under subsystem app.splynek, category system. View with: log stream --predicate 'subsystem == \"app.splynek\"' --info": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Tool-Aufrufe werden über os.Logger unter Subsystem app.splynek, Kategorie system protokolliert. Anzeige mit: log stream --predicate 'subsystem == \"app.splynek\"' --info"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas las llamadas a herramientas se registran vía os.Logger bajo subsistema app.splynek, categoría system. Ver con: log stream --predicate 'subsystem == \"app.splynek\"' --info"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous les appels d'outils sont consignés via os.Logger sous le sous-système app.splynek, catégorie system. À voir avec : log stream --predicate 'subsystem == \"app.splynek\"' --info"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutte le chiamate agli strumenti sono registrate via os.Logger sotto sottosistema app.splynek, categoria system. Vedi con: log stream --predicate 'subsystem == \"app.splynek\"' --info"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as chamadas de ferramentas são registadas via os.Logger no subsistema app.splynek, categoria system. Vê com: log stream --predicate 'subsystem == \"app.splynek\"' --info"
          }
        }
      }
    },
