    "Add a URL to the queue from the Downloads tab — Splynek will run it when the current download finishes.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie eine URL aus dem Downloads-Tab zur Warteschlange hinzu — Splynek führt sie aus, wenn der aktuelle Download fertig ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade una URL a la cola desde la pestaña Descargas — Splynek la ejecutará cuando termine la descarga actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez une URL à la file depuis l'onglet Téléchargements — Splynek l'exécutera quand le téléchargement actuel se terminera."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un URL alla coda dalla scheda Download — Splynek lo eseguirà quando il download attuale finisce."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Adiciona um URL à fila a partir do separador Transferências — o Splynek executa-o quando a transferência atual terminar."
          }
        }
      }
    },
