        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous n'en avez pas ? Passez — Splynek téléchargera quand même le fichier, juste sans la vérification supplémentaire."
          }
        },
        "it": {
          "stringUnit": {
