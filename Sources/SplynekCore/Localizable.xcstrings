    "Other Splynek Macs on your LAN, advertised over Bonjour. Shared files skip the internet — downloads go Mac-to-Mac at gigabit.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Andere Splynek-Macs in Ihrem lokalen Netzwerk, angekündigt über Bonjour. Geteilte Dateien überspringen das Internet — Downloads laufen Mac-zu-Mac mit Gigabit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Otros Macs con Splynek en tu red local, anunciados vía Bonjour. Los archivos compartidos se saltan internet — las descargas van Mac-a-Mac a gigabit."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autres Macs avec Splynek sur votre réseau local, annoncés via Bonjour. Les fichiers partagés sautent Internet — les téléchargements vont Mac-à-Mac à gigabit."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Altri Mac con Splynek sulla tua rete locale, annunciati via Bonjour. I file condivisi saltano Internet — i download vanno Mac-a-Mac a gigabit."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Outros Macs com Splynek na tua rede local, anunciados via Bonjour. Os ficheiros partilhados saltam a Internet — as transferências vão Mac-a-Mac a velocidades gigabit."
          }
        }
      }
    },
