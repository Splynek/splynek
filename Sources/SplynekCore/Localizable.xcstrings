    "Skipped — %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Übersprungen — %@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Omitido — %@"
          }
        },
