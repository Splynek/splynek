    "Start download now (⏎). Pulls the URL across every selected interface in parallel.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Download jetzt starten (⏎). Lädt die URL parallel über alle ausgewählten Schnittstellen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar descarga ahora (⏎). Tira de la URL por todas las interfaces seleccionadas en paralelo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Démarrer le téléchargement maintenant (⏎). Tire l'URL sur toutes les interfaces sélectionnées en parallèle."
