        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar descarga ahora (⏎). Tira de la URL por todas las interfaces seleccionadas en paralelo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Démarrer le téléchargement maintenant (⏎). Tire l'URL sur toutes les interfaces sélectionnées en parallèle."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Avvia download ora (⏎). Preleva l'URL su tutte le interfacce selezionate in parallelo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar transferência agora (⏎). Puxa o URL por todas as interfaces selecionadas em paralelo."
          }
        }
      }
    },
    "Start one from the Downloads tab or the Assistant, and it'll show up here in real time.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Starten Sie einen aus dem Downloads-Tab oder dem Assistenten, und er erscheint hier in Echtzeit."
