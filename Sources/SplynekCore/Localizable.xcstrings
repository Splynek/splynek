    "Updates download via Splynek’s bonded multi-interface fetch and verify with an Ed25519 receipt before installing. Click Update on a row to start.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Updates werden über Splyneks gebündelten Multi-Interface-Download geladen und vor der Installation mit einer Ed25519-Quittung verifiziert. Klicke in einer Zeile auf Aktualisieren, um zu starten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las actualizaciones se descargan mediante la descarga multi-interfaz combinada de Splynek y se verifican con un recibo Ed25519 antes de instalar. Haz clic en Actualizar en una fila para empezar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les mises à jour se téléchargent via le fetch multi-interfaces combiné de Splynek et sont vérifiées par un reçu Ed25519 avant l’installation. Clique sur Mettre à jour sur une ligne pour commencer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli aggiornamenti si scaricano tramite il fetch multi-interfaccia bonded di Splynek e vengono verificati con una ricevuta Ed25519 prima dell’installazione. Clicca su Aggiorna su una riga per iniziare."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "As atualizações descarregam via fetch multi-interface bonded do Splynek e são verificadas com um recibo Ed25519 antes de instalar. Clica em Atualizar numa linha para começar."
          }
        }
      }
    },
