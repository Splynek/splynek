    "Remove this app from your migration list. The original app stays installed; we just stop reminding.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernt diese App aus Ihrer Migrationsliste. Die Original-App bleibt installiert; wir hören nur auf, Sie zu erinnern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Quita esta app de tu lista de migración. La app original sigue instalada; solo dejamos de recordártelo."
          }
        },
        "fr": {
