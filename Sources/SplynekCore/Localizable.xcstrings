    "What the engine is doing right now. One section per running download — throughput, interface breakdown, pipeline stage.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was die Engine gerade tut. Ein Abschnitt pro laufendem Download — Durchsatz, Schnittstellen-Aufschlüsselung, Pipeline-Phase."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lo que el motor está haciendo ahora. Una sección por descarga en curso — ancho de banda, desglose por interfaz, fase del pipeline."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce que le moteur fait en ce moment. Une section par téléchargement en cours — débit, répartition par interface, étape du pipeline."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cosa sta facendo il motore in questo momento. Una sezione per ogni download in corso — throughput, suddivisione per interfaccia, fase pipeline."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O que o motor está a fazer agora. Uma secção por transferência em curso — débito, divisão por interface, fase do pipeline."
          }
        }
      }
    },
