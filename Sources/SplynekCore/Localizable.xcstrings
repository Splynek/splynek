    "Verify the server's responding without leaving Splynek. Picks the same endpoint you'd give a remote client.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Prüft, ob der Server antwortet, ohne Splynek zu verlassen. Verwendet denselben Endpunkt, den Sie einem entfernten Client geben würden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifica que el servidor responde sin salir de Splynek. Usa el mismo endpoint que darías a un cliente remoto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vérifie que le serveur répond sans quitter Splynek. Utilise le même point d'accès que vous donneriez à un client distant."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifica che il server risponda senza uscire da Splynek. Usa lo stesso endpoint che daresti a un client remoto."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Verifica se o servidor responde sem sair do Splynek. Usa o mesmo endpoint que darias a um cliente remoto."
          }
        }
      }
    },
