        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa app non è più in \\(r.installedAt.path). Dimentica la voce per ripulirla."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta app já não está em \\(r.installedAt.path). Esquece a entrada para limpá-la."
          }
        }
      }
    },
    "This download has %lld fleet-peer mirror(s) cooperating on the LAN.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Download hat %lld Flotten-Peer-Spiegel, die im LAN kooperieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta descarga tiene %lld mirror(s) de la flota cooperando en la red local."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce téléchargement a %lld miroir(s) de flotte coopérant sur le réseau local."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo download ha %lld mirror della flotta che cooperano sulla rete locale."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
