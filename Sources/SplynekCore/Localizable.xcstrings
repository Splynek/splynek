    "Tell it what you want to set up. Get a download plan.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sagen Sie ihm, was Sie einrichten möchten. Erhalten Sie einen Download-Plan."
          }
        },
        "es": {
