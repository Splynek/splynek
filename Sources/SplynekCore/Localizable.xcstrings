    "Stop sharing this file with other Splyneks on the LAN. The file and history entry are kept; only fleet sharing stops.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Datei nicht mehr mit anderen Splyneks im LAN teilen. Datei und Verlaufseintrag bleiben erhalten; nur die Flotten-Freigabe wird beendet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dejar de compartir este archivo con otros Splyneks en la red local. El archivo y la entrada en el historial se conservan; solo se detiene el uso compartido por la flota."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cesser de partager ce fichier avec les autres Splyneks du réseau local. Le fichier et l'entrée d'historique sont conservés ; seul le partage par la flotte s'arrête."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Smetti di condividere questo file con gli altri Splynek nella rete locale. Il file e la voce di cronologia vengono mantenuti; si interrompe solo la condivisione tramite flotta."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Parar de partilhar este ficheiro com outros Splyneks na rede local. O ficheiro e a entrada no histórico são mantidos; só a partilha pela Frota termina."
          }
        }
      }
    },
