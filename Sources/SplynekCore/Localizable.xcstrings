    "Off by default. Flip the switch above to enable agents to call Splynek.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standardmäßig deaktiviert. Aktivieren Sie den Schalter oben, damit Agenten Splynek aufrufen können."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactivado por defecto. Activa el interruptor de arriba para permitir que los agentes llamen a Splynek."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactivé par défaut. Activez le commutateur ci-dessus pour permettre aux agents d'appeler Splynek."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disattivato per impostazione predefinita. Attiva l'interruttore sopra per consentire agli agenti di chiamare Splynek."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Desligado por predefinição. Ativa o interruptor acima para permitir que agentes chamem o Splynek."
          }
        }
      }
    },
    "Off by default. The toggle above is the only way in.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Standardmäßig aus. Der Schalter oben ist der einzige Weg hinein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactivado por defecto. El interruptor de arriba es la única forma de entrar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactivé par défaut. Le commutateur ci-dessus est la seule façon d'entrer."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disattivato per impostazione predefinita. L'interruttore sopra è l'unico modo per entrare."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Desligado por predefinição. O interruptor acima é a única forma de entrar."
          }
        }
      }
    },
    "Once the download finishes, keep serving pieces to other peers.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn der Download fertig ist, weiterhin Stücke an andere Peers ausliefern."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando termine la descarga, sigue sirviendo fragmentos a otros pares."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois le téléchargement terminé, continue à servir des morceaux aux autres pairs."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando il download finisce, continua a servire frammenti agli altri peer."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando a transferência terminar, continua a servir fragmentos a outros pares."
          }
        }
      }
    },
    "One-time purchase. Lifetime 0.x updates.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einmaliger Kauf. Lebenslange 0.x-Updates."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Compra única. Actualizaciones 0.x de por vida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Achat unique. Mises à jour 0.x à vie."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Acquisto unico. Aggiornamenti 0.x a vita."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Compra única. Atualizações 0.x para sempre."
          }
        }
      }
    },
    "Only start queued downloads inside a time window — e.g., overnight on home Wi-Fi. Running downloads are never interrupted; the schedule only gates starts.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geplante Downloads nur innerhalb eines Zeitfensters starten — z. B. nachts im Heim-WLAN. Laufende Downloads werden nie unterbrochen; der Zeitplan reguliert nur Starts."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar las descargas en cola solo dentro de una ventana horaria — por ejemplo, de noche en el Wi-Fi de casa. Las descargas en curso nunca se interrumpen; la planificación solo regula los inicios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lancer les téléchargements en file uniquement dans une fenêtre horaire — par exemple la nuit sur le Wi-Fi domestique. Les téléchargements en cours ne sont jamais interrompus ; la planification ne contrôle que les démarrages."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Avvia i download in coda solo all'interno di una finestra temporale — ad esempio di notte sul Wi-Fi di casa. I download in corso non vengono mai interrotti; la pianificazione regola solo gli avvii."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar transferências em fila apenas dentro de uma janela horária — por exemplo, de noite no Wi-Fi de casa. As transferências em curso nunca são interrompidas; o agendamento controla apenas o arranque."
          }
        }
      }
    },
