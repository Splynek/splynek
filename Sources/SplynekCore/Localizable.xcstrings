    "Add to queue (⌘⇧Q). Runs when the current download finishes.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zur Warteschlange hinzufügen (⌘⇧Q). Startet, wenn der aktuelle Download fertig ist."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añadir a la cola (⌘⇧Q). Empieza cuando termine la descarga actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajouter à la file (⌘⇧Q). Démarre quand le téléchargement actuel se termine."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi alla coda (⌘⇧Q). Parte quando il download attuale finisce."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicionar à fila (⌘⇧Q). Começa quando a transferência atual terminar."
          }
        }
      }
    },
