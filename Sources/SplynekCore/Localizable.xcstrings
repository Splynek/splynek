          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove esta app da tua lista de migração. A app original continua instalada; só deixamos de te lembrar."
          }
        }
      }
    },
    "Remove this row from history. The downloaded file stays on disk.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Zeile aus dem Verlauf entfernen. Die heruntergeladene Datei bleibt auf der Festplatte."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar esta fila del historial. El archivo descargado queda en disco."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer cette ligne de l’historique. Le fichier téléchargé reste sur le disque."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuovi questa riga dalla cronologia. Il file scaricato resta sul disco."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Remover esta linha do histórico. O ficheiro descarregado fica no disco."
          }
        }
      }
    },
    "Removes every entry from the history log. Does NOT delete any downloaded files — only the log.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernt jeden Eintrag aus dem Verlaufsprotokoll. Löscht KEINE heruntergeladenen Dateien — nur das Protokoll."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina todas las entradas del registro de historial. NO elimina archivos descargados — solo el registro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Retire toutes les entrées de l’historique. Ne supprime AUCUN fichier téléchargé — uniquement le journal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuove tutte le voci dal registro della cronologia. NON elimina alcun file scaricato — solo il registro."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove todas as entradas do histórico. NÃO elimina ficheiros descarregados — apenas o registo."
          }
        }
      }
    },
    "Removes the entry from Splynek's registry. Does NOT uninstall the .app — drag it to the Trash separately.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entfernt den Eintrag aus dem Splynek-Register. Deinstalliert die .app NICHT — ziehe sie separat in den Papierkorb."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
