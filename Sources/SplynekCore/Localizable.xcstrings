    "Stays on-device — no network calls, ever": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bleibt auf dem Gerät — niemals Netzwerkaufrufe"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permanece en el dispositivo — nunca hay llamadas de red"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reste sur l'appareil — aucun appel réseau, jamais"
          }
        },
        "it": {
