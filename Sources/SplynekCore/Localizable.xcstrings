    "Unlock the AI Concierge, AI-powered history search, scheduled downloads, and phone-accessible LAN dashboard. One-time $29; lifetime 0.x updates.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalten Sie KI-Concierge, KI-Verlaufssuche, geplante Downloads und vom Telefon zugängliches Dashboard über lokales Netzwerk frei. Einmaliger Kauf $29; lebenslange 0.x-Updates."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloquea el Concierge IA, búsqueda de historial con IA, descargas programadas y panel accesible desde el teléfono vía red local. Compra única $29; actualizaciones 0.x de por vida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Débloquez le Concierge IA, recherche d'historique IA, téléchargements planifiés et tableau de bord accessible par téléphone via réseau local. Achat unique $29 ; mises à jour 0.x à vie."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca il Concierge IA, ricerca cronologia con IA, download programmati e dashboard accessibile dal telefono via rete locale. Acquisto unico $29; aggiornamenti 0.x a vita."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueia o Concierge IA, pesquisa de histórico com IA, transferências agendadas e painel acessível pelo telemóvel via rede local. Compra única $29; atualizações 0.x para sempre."
          }
        }
