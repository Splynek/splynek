    "Re-queue every failed or cancelled entry. Runs immediately if nothing else is running.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle fehlgeschlagenen oder abgebrochenen Einträge erneut einreihen. Startet sofort, wenn nichts anderes läuft."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Volver a poner en cola cada entrada fallida o cancelada. Comienza de inmediato si no hay nada más en marcha."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Remettre en file toutes les entrées ayant échoué ou annulées. Démarre immédiatement si rien d'autre n'est en cours."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimetti in coda ogni voce fallita o annullata. Parte subito se non c'è nient'altro in esecuzione."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Voltar a colocar na fila todas as entradas falhadas ou canceladas. Inicia de imediato se nada estiver em curso."
          }
        }
      }
    },
    "Re-run with the same target. Useful after switching networks.": {
      "localizations": {
        "de": {
          "stringUnit": {
