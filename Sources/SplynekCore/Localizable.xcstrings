    "Recipes run entirely on your Mac. Pick an option — Splynek auto-detects whichever is ready. No cloud, no account, no telemetry.": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Rezepte laufen vollständig auf deinem Mac. Wähle eine Option — Splynek erkennt automatisch, welche bereit ist. Keine Cloud, kein Konto, keine Telemetrie."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las recetas se ejecutan enteramente en tu Mac. Elige una opción — Splynek detecta automáticamente la que esté lista. Sin nube, sin cuenta, sin telemetría."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les recettes s'exécutent entièrement sur ton Mac. Choisis une option — Splynek détecte automatiquement celle qui est prête. Pas de cloud, pas de compte, pas de télémétrie."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le ricette girano interamente sul tuo Mac. Scegli un'opzione — Splynek rileva automaticamente quella pronta. Niente cloud, niente account, niente telemetria."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "As receitas correm inteiramente no teu Mac. Escolhe uma opção — o Splynek deteta automaticamente qual está pronta. Sem cloud, sem conta, sem telemetria."
          }
        }
      }
    },
