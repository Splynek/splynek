{
  "sourceLanguage": "en",
  "strings": {
    "$29 one-time on the Mac App Store.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "$29 einmalig im Mac App Store."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "$29 pago único en la Mac App Store."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "$29 achat unique sur le Mac App Store."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "$29 acquisto unico nel Mac App Store."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "$29 compra única na Mac App Store."
          }
        }
      }
    },
    "%1$lld / %2$lld apps": {
      "comment": "Match summary shown above the results list. %1$lld = matched count, %2$lld = total scanned.",
