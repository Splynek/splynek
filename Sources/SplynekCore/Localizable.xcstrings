      }
    },
    "Search by app name" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Nach App-Namen suchen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Buscar por nombre de app" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Rechercher par nom d'app" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Cerca per nome app" } }
      }
    },
    "Details + alternatives" : {
      "comment" : "v1.5.1 — was 'Details + better alternatives'; dropped 'better' as editorial.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Details + Alternativen" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Detalles + alternativas" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Détails + alternatives" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Dettagli + alternative" } }
      }
    },
    "Alternatives" : {
