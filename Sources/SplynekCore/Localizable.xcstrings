    "Open Splynek Companion on your iPhone, tap +, then Scan QR. Pairing is instant — no token paste.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Splynek Companion auf dem iPhone öffnen, auf + tippen, dann QR scannen. Kopplung ist sofort — kein Token einzufügen."
          }
        },
        "es": {
