    "Catalog covers 1,100+ apps. Community PRs at github.com/Splynek/splynek expand it.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Katalog umfasst über 1 100 Apps. Community-PRs auf github.com/Splynek/splynek erweitern ihn."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El catálogo cubre más de 1100 apps. Los PR de la comunidad en github.com/Splynek/splynek lo amplían."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le catalogue couvre plus de 1 100 apps. Les PR de la communauté sur github.com/Splynek/splynek l'étendent."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il catalogo copre oltre 1100 app. Le PR della community su github.com/Splynek/splynek lo ampliano."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O catálogo cobre mais de 1100 apps. PRs da comunidade em github.com/Splynek/splynek alargam-no."
          }
        }
      }
    },
    "Catalog data ships in the app — neither Sovereignty nor Trust lookups query a network service. Your installed-app list never leaves your Mac.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Katalog-Daten werden mit der App ausgeliefert — weder Souveränität- noch Vertrauen-Abfragen kontaktieren einen Netzwerkdienst. Ihre Liste installierter Apps verlässt Ihren Mac nie."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los datos del catálogo se envían en la app — ni Soberanía ni Confianza consultan un servicio de red. Tu lista de apps instaladas nunca sale del Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les données du catalogue sont incluses dans l'app — ni Souveraineté ni Confiance n'interrogent un service réseau. Votre liste d'apps installées ne quitte jamais votre Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I dati del catalogo vengono distribuiti nell'app — né Sovranità né Affidabilità interrogano un servizio di rete. Il tuo elenco di app installate non lascia mai il Mac."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os dados do catálogo são enviados na app — nem as consultas Soberania nem Confiança consultam um serviço de rede. A tua lista de apps instaladas nunca sai do Mac."
          }
        }
      }
    },
