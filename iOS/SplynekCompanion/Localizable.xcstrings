      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Mac verbinden" } },
        "es": { "stringUnit": { "state": "translated", "value": "Emparejar un Mac" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Appairer un Mac" } },
        "it": { "stringUnit": { "state": "translated", "value": "Abbina un Mac" } },
