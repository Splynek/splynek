    "Pairing…": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Verbinden …" } },
        "es": { "stringUnit": { "state": "translated", "value": "Emparejando…" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Appairage…" } },
        "it": { "stringUnit": { "state": "translated", "value": "Abbinamento…" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "A emparelhar…" } }
      }
    },
    "Paste from clipboard": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Aus Zwischenablage einfügen" } },
        "es": { "stringUnit": { "state": "translated", "value": "Pegar del portapapeles" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Coller depuis le presse-papiers" } },
        "it": { "stringUnit": { "state": "translated", "value": "Incolla dagli appunti" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Colar da área de transferência" } }
      }
    },
    "Paste from Mac → Settings → Sharing": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Vom Mac → Einstellungen → Teilen einfügen" } },
        "es": { "stringUnit": { "state": "translated", "value": "Pegar desde Mac → Ajustes → Compartir" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Coller depuis Mac → Réglages → Partage" } },
        "it": { "stringUnit": { "state": "translated", "value": "Incolla da Mac → Impostazioni → Condivisione" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Colar do Mac → Definições → Partilha" } }
      }
    },
    "Point at the QR in Splynek → Settings → Web dashboard": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Auf den QR in Splynek → Einstellungen → Web-Dashboard zielen" } },
        "es": { "stringUnit": { "state": "translated", "value": "Apunta al QR en Splynek → Ajustes → Panel web" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Vise le QR dans Splynek → Réglages → Tableau web" } },
        "it": { "stringUnit": { "state": "translated", "value": "Inquadra il QR in Splynek → Impostazioni → Dashboard web" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Aponta para o QR em Splynek → Definições → Painel web" } }
      }
    },
    "Port (default 18280)": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Port (Standard 18280)" } },
        "es": { "stringUnit": { "state": "translated", "value": "Puerto (predeterminado 18280)" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Port (par défaut 18280)" } },
        "it": { "stringUnit": { "state": "translated", "value": "Porta (predefinita 18280)" } },
