    "Submit": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Senden" } },
        "es": { "stringUnit": { "state": "translated", "value": "Enviar" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Envoyer" } },
        "it": { "stringUnit": { "state": "translated", "value": "Invia" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Enviar" } }
      }
    },
    "Submit URL": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "URL senden" } },
        "es": { "stringUnit": { "state": "translated", "value": "Enviar URL" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Envoyer un URL" } },
        "it": { "stringUnit": { "state": "translated", "value": "Invia URL" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Enviar URL" } }
      }
    },
    "Tap Test pairing to send a /status request and confirm the token + LAN route are healthy.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Tippe auf „Verbindung testen\", um eine /status-Anfrage zu senden und den Token + die LAN-Route zu bestätigen." } },
        "es": { "stringUnit": { "state": "translated", "value": "Pulsa Probar emparejamiento para enviar una solicitud /status y confirmar que el token y la ruta LAN están bien." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Appuie sur Tester l'appairage pour envoyer une requête /status et confirmer que le jeton et la route LAN sont OK." } },
        "it": { "stringUnit": { "state": "translated", "value": "Tocca Verifica abbinamento per inviare una richiesta /status e confermare che token e percorso LAN siano OK." } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Toca em Testar emparelhamento para enviar um pedido /status e confirmar que o token + rota LAN estão saudáveis." } }
      }
    },
    "Test pairing": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Verbindung testen" } },
        "es": { "stringUnit": { "state": "translated", "value": "Probar emparejamiento" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Tester l'appairage" } },
        "it": { "stringUnit": { "state": "translated", "value": "Verifica abbinamento" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Testar emparelhamento" } }
      }
    },
    "This extension works on URL-shaped content — articles, video pages, file links, etc.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Diese Erweiterung funktioniert mit URL-Inhalten — Artikel, Video-Seiten, Datei-Links usw." } },
        "es": { "stringUnit": { "state": "translated", "value": "Esta extensión funciona con contenido tipo URL — artículos, páginas de vídeo, enlaces a archivos, etc." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Cette extension fonctionne avec du contenu URL — articles, pages vidéo, liens de fichier, etc." } },
        "it": { "stringUnit": { "state": "translated", "value": "Questa estensione funziona con contenuti URL — articoli, pagine video, link a file, ecc." } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Esta extensão funciona com conteúdos URL — artigos, páginas de vídeo, ligações para ficheiros, etc." } }
      }
    },
    "Token": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Token" } },
        "es": { "stringUnit": { "state": "translated", "value": "Token" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Jeton" } },
        "it": { "stringUnit": { "state": "translated", "value": "Token" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Token" } }
      }
    },
    "URL": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "URL" } },
        "es": { "stringUnit": { "state": "translated", "value": "URL" } },
        "fr": { "stringUnit": { "state": "translated", "value": "URL" } },
        "it": { "stringUnit": { "state": "translated", "value": "URL" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "URL" } }
      }
    },
    "URL to download": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "URL zum Herunterladen" } },
        "es": { "stringUnit": { "state": "translated", "value": "URL para descargar" } },
        "fr": { "stringUnit": { "state": "translated", "value": "URL à télécharger" } },
        "it": { "stringUnit": { "state": "translated", "value": "URL da scaricare" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "URL para transferir" } }
      }
    },
    "URLs only send over local Wi-Fi. Submissions fail when the Mac is unreachable.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "URLs werden nur über lokales WLAN gesendet. Übermittlungen scheitern, wenn der Mac nicht erreichbar ist." } },
        "es": { "stringUnit": { "state": "translated", "value": "Los URLs solo se envían por Wi-Fi local. Los envíos fallan si el Mac no está accesible." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Les URLs n'envoient que par Wi-Fi local. L'envoi échoue si le Mac n'est pas joignable." } },
        "it": { "stringUnit": { "state": "translated", "value": "Gli URL si inviano solo via Wi-Fi locale. L'invio fallisce se il Mac non è raggiungibile." } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Os URLs só são enviados por Wi-Fi local. Os envios falham quando o Mac está inacessível." } }
      }
    },
    "Version": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Version" } },
        "es": { "stringUnit": { "state": "translated", "value": "Versión" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Version" } },
        "it": { "stringUnit": { "state": "translated", "value": "Versione" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Versão" } }
      }
    },
    "When the iPhone can't reach the Mac over Wi-Fi, the URL is sent through your private iCloud database. The Mac picks it up within 60 seconds the next time it polls. Nothing leaves your iCloud account.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Wenn das iPhone den Mac nicht über WLAN erreicht, wird die URL über deine private iCloud-Datenbank gesendet. Der Mac holt sie innerhalb von 60 Sekunden beim nächsten Abruf ab. Nichts verlässt deinen iCloud-Account." } },
        "es": { "stringUnit": { "state": "translated", "value": "Cuando el iPhone no llega al Mac por Wi-Fi, el URL se envía por tu base de datos privada de iCloud. El Mac la recoge en 60 segundos en el siguiente sondeo. Nada sale de tu cuenta de iCloud." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Quand l'iPhone n'atteint pas le Mac en Wi-Fi, l'URL passe par ta base privée iCloud. Le Mac la récupère sous 60 secondes au prochain sondage. Rien ne quitte ton compte iCloud." } },
        "it": { "stringUnit": { "state": "translated", "value": "Quando l'iPhone non raggiunge il Mac in Wi-Fi, l'URL passa per il tuo database iCloud privato. Il Mac la recupera entro 60 secondi al prossimo poll. Niente lascia il tuo account iCloud." } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Quando o iPhone não chega ao Mac por Wi-Fi, o URL passa pela tua base de dados privada do iCloud. O Mac apanha-o em 60 segundos no próximo poll. Nada sai da tua conta iCloud." } }
      }
    }
  },
  "version": "1.0"
}
