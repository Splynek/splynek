    "Queue download": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Download in Warteschlange" } },
        "es": { "stringUnit": { "state": "translated", "value": "Poner descarga en cola" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Mettre en file d'attente" } },
        "it": { "stringUnit": { "state": "translated", "value": "Aggiungi in coda" } },
