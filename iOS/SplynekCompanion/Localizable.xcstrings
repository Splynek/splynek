      }
    },
    "Reachable via iCloud": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Über iCloud erreichbar" } },
        "es": { "stringUnit": { "state": "translated", "value": "Accesible vía iCloud" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Accessible via iCloud" } },
        "it": { "stringUnit": { "state": "translated", "value": "Raggiungibile tramite iCloud" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Acessível via iCloud" } }
      }
    },
    "Relay": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Relais" } },
        "es": { "stringUnit": { "state": "translated", "value": "Reenvío" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Relais" } },
        "it": { "stringUnit": { "state": "translated", "value": "Inoltro" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Reencaminhamento" } }
      }
    },
    "Scan QR from Mac": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "QR vom Mac scannen" } },
        "es": { "stringUnit": { "state": "translated", "value": "Escanear QR del Mac" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Scanner le QR du Mac" } },
        "it": { "stringUnit": { "state": "translated", "value": "Scansiona il QR dal Mac" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Ler QR do Mac" } }
      }
    },
    "Send": {
