    "Faster — open Splynek on your Mac, go to Settings → Web dashboard, and aim at the iPhone-pair QR.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schneller — öffne Splynek auf deinem Mac, gehe zu Einstellungen → Web-Dashboard und richte die Kamera auf den iPhone-Pair-QR."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Más rápido — abre Splynek en tu Mac, ve a Ajustes → Panel web y apunta al QR de emparejamiento del iPhone."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Plus rapide — ouvre Splynek sur ton Mac, va dans Réglages → Tableau web et vise le QR d'appairage iPhone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Più veloce — apri Splynek sul Mac, vai in Impostazioni → Dashboard web e inquadra il QR di abbinamento iPhone."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Mais rápido — abre o Splynek no Mac, vai a Definições → Painel web e aponta para o QR de emparelhamento iPhone."
          }
        }
      }
    },
