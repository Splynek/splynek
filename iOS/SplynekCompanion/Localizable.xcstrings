{
  "sourceLanguage": "en",
  "strings": {
    "About": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Über" } },
        "es": { "stringUnit": { "state": "translated", "value": "Acerca de" } },
        "fr": { "stringUnit": { "state": "translated", "value": "À propos" } },
        "it": { "stringUnit": { "state": "translated", "value": "Informazioni" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Sobre" } }
      }
    },
    "Build": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Build" } },
        "es": { "stringUnit": { "state": "translated", "value": "Build" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Build" } },
        "it": { "stringUnit": { "state": "translated", "value": "Build" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Build" } }
      }
    },
    "Cancel": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Abbrechen" } },
        "es": { "stringUnit": { "state": "translated", "value": "Cancelar" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Annuler" } },
        "it": { "stringUnit": { "state": "translated", "value": "Annulla" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Cancelar" } }
      }
    },
    "Couldn't find a URL to share": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Keine URL zum Teilen gefunden" } },
        "es": { "stringUnit": { "state": "translated", "value": "No se encontró ninguna URL para compartir" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Aucune URL trouvée à partager" } },
        "it": { "stringUnit": { "state": "translated", "value": "Nessun URL trovato da condividere" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Não foi encontrado um URL para partilhar" } }
      }
    },
    "Discovered on this network": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "In diesem Netzwerk gefunden" } },
        "es": { "stringUnit": { "state": "translated", "value": "Detectados en esta red" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Détectés sur ce réseau" } },
        "it": { "stringUnit": { "state": "translated", "value": "Rilevati su questa rete" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Detetados nesta rede" } }
      }
    },
    "Faster — open Splynek on your Mac, go to Settings → Web dashboard, and aim at the iPhone-pair QR.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Schneller — öffne Splynek auf deinem Mac, gehe zu Einstellungen → Web-Dashboard und richte die Kamera auf den iPhone-Pair-QR." } },
        "es": { "stringUnit": { "state": "translated", "value": "Más rápido — abre Splynek en tu Mac, ve a Ajustes → Panel web y apunta al QR de emparejamiento del iPhone." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Plus rapide — ouvre Splynek sur ton Mac, va dans Réglages → Tableau web et vise le QR d'appairage iPhone." } },
        "it": { "stringUnit": { "state": "translated", "value": "Più veloce — apri Splynek sul Mac, vai in Impostazioni → Dashboard web e inquadra il QR di abbinamento iPhone." } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Mais rápido — abre o Splynek no Mac, vai a Definições → Painel web e aponta para o QR de emparelhamento iPhone." } }
      }
    },
    "Host (e.g. mac.local or 192.168.1.20)": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Host (z. B. mac.local oder 192.168.1.20)" } },
        "es": { "stringUnit": { "state": "translated", "value": "Host (p. ej. mac.local o 192.168.1.20)" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Hôte (ex. mac.local ou 192.168.1.20)" } },
        "it": { "stringUnit": { "state": "translated", "value": "Host (es. mac.local o 192.168.1.20)" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Anfitrião (ex. mac.local ou 192.168.1.20)" } }
      }
    },
    "Mac": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Mac" } },
        "es": { "stringUnit": { "state": "translated", "value": "Mac" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Mac" } },
        "it": { "stringUnit": { "state": "translated", "value": "Mac" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Mac" } }
      }
    },
    "Macs": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Macs" } },
        "es": { "stringUnit": { "state": "translated", "value": "Macs" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Macs" } },
        "it": { "stringUnit": { "state": "translated", "value": "Macs" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Macs" } }
      }
    },
    "Name (e.g. Paulo's MacBook)": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Name (z. B. Paulos MacBook)" } },
        "es": { "stringUnit": { "state": "translated", "value": "Nombre (p. ej. el MacBook de Paulo)" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Nom (ex. MacBook de Paulo)" } },
        "it": { "stringUnit": { "state": "translated", "value": "Nome (es. MacBook di Paulo)" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Nome (ex. MacBook do Paulo)" } }
      }
    },
    "No Macs paired. Switch to the Macs tab to pair one first.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Keine Macs verbunden. Wechsle zum Macs-Tab, um einen zu verbinden." } },
        "es": { "stringUnit": { "state": "translated", "value": "Ningún Mac emparejado. Cambia a la pestaña Macs para emparejar uno." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Aucun Mac appairé. Va dans l'onglet Macs pour en appairer un." } },
        "it": { "stringUnit": { "state": "translated", "value": "Nessun Mac abbinato. Vai alla scheda Macs per abbinarne uno." } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Nenhum Mac emparelhado. Muda para o separador Macs para emparelhar um." } }
      }
    },
    "No Macs paired yet": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Noch keine Macs verbunden" } },
        "es": { "stringUnit": { "state": "translated", "value": "Aún no hay ningún Mac emparejado" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Aucun Mac appairé pour le moment" } },
        "it": { "stringUnit": { "state": "translated", "value": "Nessun Mac abbinato" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Ainda não há Macs emparelhados" } }
      }
    },
    "No Macs paired yet. Add one from the Macs tab.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Noch keine Macs verbunden. Füge einen über den Macs-Tab hinzu." } },
        "es": { "stringUnit": { "state": "translated", "value": "Aún no hay ningún Mac emparejado. Añade uno desde la pestaña Macs." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Aucun Mac appairé pour le moment. Ajoutes-en un depuis l'onglet Macs." } },
        "it": { "stringUnit": { "state": "translated", "value": "Nessun Mac abbinato. Aggiungine uno dalla scheda Macs." } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Ainda não há Macs emparelhados. Adiciona um a partir do separador Macs." } }
      }
    },
    "No active downloads": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Keine aktiven Downloads" } },
        "es": { "stringUnit": { "state": "translated", "value": "No hay descargas activas" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Aucun téléchargement en cours" } },
        "it": { "stringUnit": { "state": "translated", "value": "Nessun download attivo" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Sem transferências ativas" } }
      }
    },
    "On this Wi-Fi": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "In diesem WLAN" } },
        "es": { "stringUnit": { "state": "translated", "value": "En esta Wi-Fi" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Sur ce Wi-Fi" } },
        "it": { "stringUnit": { "state": "translated", "value": "Su questa Wi-Fi" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Nesta Wi-Fi" } }
      }
    },
    "Open Splynek Companion to pair your Mac, then come back here.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Öffne Splynek Companion, um deinen Mac zu verbinden, und komm dann zurück." } },
        "es": { "stringUnit": { "state": "translated", "value": "Abre Splynek Companion para emparejar tu Mac y vuelve aquí." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Ouvre Splynek Companion pour appairer ton Mac, puis reviens ici." } },
        "it": { "stringUnit": { "state": "translated", "value": "Apri Splynek Companion per abbinare il Mac, poi torna qui." } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Abre o Splynek Companion para emparelhar o teu Mac e volta aqui." } }
      }
    },
    "Open Splynek on your Mac, go to Settings → Sharing, and tap the copy-token button.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Öffne Splynek auf deinem Mac, gehe zu Einstellungen → Teilen und tippe auf „Token kopieren\"." } },
        "es": { "stringUnit": { "state": "translated", "value": "Abre Splynek en tu Mac, ve a Ajustes → Compartir y pulsa el botón Copiar token." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Ouvre Splynek sur ton Mac, va dans Réglages → Partage et appuie sur Copier le jeton." } },
        "it": { "stringUnit": { "state": "translated", "value": "Apri Splynek sul Mac, vai in Impostazioni → Condivisione e tocca Copia token." } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Abre o Splynek no Mac, vai a Definições → Partilha e toca em Copiar token." } }
      }
    },
    "Open Splynek on your Mac, then tap + to pair.": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Öffne Splynek auf deinem Mac und tippe dann auf +, um zu verbinden." } },
        "es": { "stringUnit": { "state": "translated", "value": "Abre Splynek en tu Mac y pulsa + para emparejar." } },
        "fr": { "stringUnit": { "state": "translated", "value": "Ouvre Splynek sur ton Mac, puis appuie sur + pour appairer." } },
        "it": { "stringUnit": { "state": "translated", "value": "Apri Splynek sul Mac, poi tocca + per abbinare." } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Abre o Splynek no Mac e toca em + para emparelhar." } }
      }
    },
    "Pair": {
      "localizations": {
        "de": { "stringUnit": { "state": "translated", "value": "Verbinden" } },
        "es": { "stringUnit": { "state": "translated", "value": "Emparejar" } },
        "fr": { "stringUnit": { "state": "translated", "value": "Appairer" } },
        "it": { "stringUnit": { "state": "translated", "value": "Abbina" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Emparelhar" } }
      }
    },
